{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": ["ES2022"],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "noEmit": true,
        "resolveJsonModule": true,
        "verbatimModuleSyntax": true,
        "types": ["node"]
    },
    "include": ["src/**/*", "test/**/*", "build.mjs"],
    "exclude": ["node_modules", "dist"]
}
